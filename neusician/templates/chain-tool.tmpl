{% extends "base.tmpl" %}
{% block heading %}Interactive demos{% endblock %}
{% block title %}Chain construction tool{% endblock %}

{% block main %}

<style>
td { height: 1em; min-width: 1em; }
td.marked { outline: 2px outset orange; }
table { border-collapse: collapse;  }
td { margin: 2px; border:3px inset grey; }
td div { background-color: grey; height: 100%; width: 100%; }
td.active-lane div { background-color: grey; }
td.merge-left { margin-left: 0; border-left: none }
td.merge-right { margin-right: 0; border-right: none; }
td.merge-top { margin-top: 0; border-top: none; }
td.merge-bottom { margin-bottom: 0; border-right: none; }
th .ui-spinner { width: 4em; }
</style>

<script>

max_lane_id = 0;
function change_state(table, new_state) {
    console.log("Change state to " + new_state);
    table = table.find("tbody");
    var lane_ids = table.data("laneids");
    var rows = table.children("tr");
    var cols = rows.eq(1).children("td").length;
    rows = rows.length - 1;
    let this_lane_id, min_lane_id;
    let mymax_lane_id = max_lane_id;
    if ( lane_ids == null ) {
         lane_ids = new Array(cols * rows);
         table.data("laneids", lane_ids);
    }
    table.children("tr").each(function (i) {
        i -= 1;
        $(this).children("td").each(function (j) {
             if ( $(this).hasClass("marked") ) {
                 if (new_state && lane_ids[ i * cols + j ] == null) {
                     this_lane_id = lane_ids[ i * cols + j ]
                     if (this_lane_id < mymax_lane_id)
                         mymax_lane_id = this_lane_id;
                     lane_ids[ i * cols + j ] = max_lane_id+1;
                     $(this).append("<div>");
                 }
                 else if (!new_state && lane_ids[ i * cols + j ]) {
                     lane_ids[ i * cols + j ] = null;
                     $(this).empty();
                 }
             	 $(this).removeClass("marked");
             }
        });
    });
}

$(function () {
    $("td").on("click", function (e) {
        e.stopImmediatePropagation();
        $(this).toggleClass("marked");
        var x = $(this).closest("tr").children("td").index(this);
        $("#in-l").val(x);
        $("#in-r").val($(this).closest("tr").children().length - x - 2);
        var y = $(this).closest("tr").index() - 1;
        $("#in-u").val(y);
        $("#in-d").val($(this).closest("tbody").children().length - y - 2);
        
    });
    $("#adder").click(function (e) {
        e.preventDefault();
        change_state($("table").first(), true);
    });
    $("#dropper").click(function (e) {
        e.preventDefault();
        change_state($("table").first(), false);
    });
    $("#in-l").spinner();
    $("#in-r").spinner();
    $("#in-u").spinner();
    $("#in-d").spinner();
});
</script>
<table border="border" style="">
<tr><th>#</th>{% for c in range(cols) %}<th>{{ c }}</th>{% endfor %}<th rowspan="{{ rows + 1 }}" style="width: 6em;">
<button id="dropper">Raus</button><br>
l: <input id="in-l" min="0"><br>
r: <input id="in-r" min="0"><br>
u: <input id="in-u" min="0"><br>
d: <input id="in-d" min="0"><br>
<button id="adder">Rein</button>
</th></tr>
{% for r in range(rows) %}
<tr><th>{{ rows-r }}</th>
{% for c in range(cols) %}<td></td>{% if r == 0 %}{% endif %}{% endfor %}
</tr>
{% endfor %}
</table>



<pre id="output"></pre>

{% endblock %}
