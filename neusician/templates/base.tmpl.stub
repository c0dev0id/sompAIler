<!DOCTYPE html>
<html>
	<head>
                <meta name="Content-Type" content="text/html; charset=utf-8" />
		<title>My Website – {% block title %}(title?){% endblock %}</title>
                <link rel="stylesheet" href="/static/jquery-ui-1.12.1.custom/jquery-ui.min.css" />
                <script type="text/javascript" src="/static/jquery-3.5.1.min.js"></script>
                <script type="text/javascript" src="/static/jquery-ui-1.12.1.custom/jquery-ui.js"></script>
                <style>{% block css %}{% endblock %}</style>
	</head>
	<body>
		<header>
			<!-- INSERT HEADER CODE HERE -->
		</header>

		<main>
			<h1>{{ self.title() }}</h1>
                        {% block main %}<p>No content</p>{% endblock %}
		</main>
                {% block articles %}{% endblock %}

		<footer><!-- INSERT FOOTER CODE HERE --></footer>
	</body>
</html>

